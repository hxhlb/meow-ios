# Template for prod.env — copy to prod.env (gitignored) and fill in.
#   cp prod.env.example prod.env
#
# Holds the production (com.tangzixiang.meow) signing config. Sourced
# automatically by scripts/build-release.sh, build-adhoc.sh, and
# upload-testflight.sh so production builds use the right team + ASC key
# without hardcoding a local key path into a committed file.

# Apple Developer team used to sign the production build. Not committed
# anywhere in git — fill in the real id here (the value lives only in prod.env).
export DEVELOPMENT_TEAM="YOUR_TEAM_ID"

# App Store Connect API key (.p8) belonging to the team above.
export ASC_KEY_ID="9FU24T97RY"
export ASC_KEY_PATH="$HOME/AuthKey_9FU24T97RY.p8"
export APP_STORE_CONNECT_API_KEY_P8="$HOME/AuthKey_9FU24T97RY.p8"

# Issuer id for the key above (App Store Connect → Users and Access →
# Integrations → App Store Connect API). Required for uploads.
export ASC_ISSUER_ID=""

# Production provisioning-profile UUIDs for the two bundle ids, once minted
# for the production team. Leave commented to use the scripts' committed defaults.
# export APP_PROFILE=""
# export PT_PROFILE=""
